generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String
  message   String
  createdAt DateTime @default(now())
}

model RevalidationEvent {
  id        String   @id @default(cuid())
  tags      String[]
  createdAt DateTime @default(now())
}

model AuditEvent {
  id        String   @id @default(cuid())
  route     String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}
